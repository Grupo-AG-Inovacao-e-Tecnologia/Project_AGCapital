{
  "name": "Project-AGCapital",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "compose:up": "docker compose up -d",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
