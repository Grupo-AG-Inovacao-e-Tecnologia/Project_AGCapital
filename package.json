    "migrate:create-only": "npx prisma migrate dev --create-only",
    "prisma:studio": "npx prisma studio",
    "ts-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nextui-org/react": "^2.6.11",
    "@prisma/client": "^5.22.0",
    "@vercel/postgres": "^0.8.0",
